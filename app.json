  "keywords": [
    "bot",
    "whatsapp",
    "keith",
    "whatsapp-stickers",
    "anime",
    "whatsapp-bot",
    "whatsapp-sticker-bot",
    "whatsapp-botto",
    "baileys",
    "baileys-md",
    "md-bot"
  ],
  "website": "https://github.com/MARC701/KEITH-MD#readme",
  "repository": "https://github.com/MARC701/KEITH-MD.git",
  "logo": "https://files.catbox.moe/qyogy8.jpg",
  "success_url": "/",
  "env": {
    "OWNER_NUMBER": {
      "description": "Bot owner phone number without + or spaces. Example: 923111977378, 923309341706",
      "value": "923111977378",
      "required": true
    },
    "SESSION": {
      "description": "Your WhatsApp session ID",
      "required": true
    },
    
    
    "DATABASE_URL": {
      "description": "insert your database url",
      "value": "",
      "required": false
    },
    
    "AUTOVIEW_STATUS": {
      "description": "Auto view WhatsApp status (true/false)",
      "value": "true",
      "required": false
    },
    "AUTOLIKE_STATUS": {
      "description": "Auto like WhatsApp status (true/false)",
      "value": "true",
      "required": false
    },
    "STATUS_LIKE_EMOJIS": {
      "description": "Emojis to use for liking status (comma-separated)",
      "value": "💛,❤️,💜,🤍,💙",
      "required": false
    },
    
    
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": true
    },
    

    
    "BOT_PIC": {
      "description": "Bot profile picture URL",
      "value": "https://files.catbox.moe/qyogy8.jpg",
      "required": true
    },
    "BOTNAME": {
      "description": "Bot display name",
      "value": "ᴍᴀʀᴄ-ᴍᴅ",
      "required": true
    },
    "OWNER_NAME": {
      "description": "add your owner name for the bot",
      "value": "𝘼𝙧𝙨𝙡𝙖𝙣 𝘾𝙝𝙖𝙪𝙙𝙖𝙧𝙮",
      "required": true
    },
    "MODE": {
      "description": "Bot operation mode (public/private)",
      "value": "public",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
    }
  ],
  "stack": "heroku-24"
}
